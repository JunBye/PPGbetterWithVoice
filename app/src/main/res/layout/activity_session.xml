<?xml version="1.0" encoding="utf-8"?>
<!-- 참가자 선택 화면: ID 직접 입력 또는 기존 참가자 드롭다운 선택 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- 앱 타이틀 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/session_title"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="40dp" />

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="24dp" />

        <!-- 기존 참가자 드롭다운 라벨 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/existing_participant_label"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginBottom="8dp" />

        <!-- 기존 참가자 스피너 -->
        <Spinner
            android:id="@+id/spinnerParticipants"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp" />

        <!-- 참가자 ID 입력 라벨 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/participant_id_label"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginBottom="8dp" />

        <!-- 참가자 ID 입력 필드 -->
        <EditText
            android:id="@+id/editParticipantId"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/participant_id_hint"
            android:inputType="textNoSuggestions"
            android:textSize="18sp"
            android:textColor="#222222"
            android:textColorHint="#AAAAAA"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="8dp" />

        <!-- ID 형식 안내 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/participant_id_format_hint"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginBottom="32dp" />

        <!-- 세션 시작 버튼 -->
        <Button
            android:id="@+id/buttonStartSession"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/start_session"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3F51B5"
            android:elevation="4dp" />

    </LinearLayout>
</ScrollView>
