<?xml version="1.0" encoding="utf-8"?>
<!-- 측정 화면: PPG 카메라 측정 + 음성 동시 녹음 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context="com.example.projekcik.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- 클립 정보 표시 (예: P01 | Part A | happy) -->
        <TextView
            android:id="@+id/tvClipInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/clip_info_none"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#3F51B5"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- 타이틀 -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="12dp" />

        <!-- 카메라 미리보기 Surface -->
        <SurfaceView
            android:id="@+id/surfaceView"
            android:layout_width="300dp"
            android:layout_height="225dp" />

        <!-- 타이머 -->
        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="18sp"
            android:layout_margin="2dp"
            android:layout_gravity="center_horizontal"/>

        <!-- 버튼 행: 측정 시작/종료 + 호흡 버튼(숨김) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/buttonToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/measurement_button_start"
                android:onClick="onToggleRecording"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:layout_marginTop="2dp"
                android:elevation="2dp" />

            <!-- 호흡 버튼 (기존 코드 유지, 실험에서는 숨김) -->
            <Button
                android:id="@+id/buttonBreath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/measurement_button_start_wd"
                android:onClick="onToggleBreath"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:layout_marginStart="2dp"
                android:layout_marginTop="2dp"
                android:elevation="2dp"
                android:enabled="false"
                android:visibility="gone" />

        </LinearLayout>

        <!-- 심박수 표시 -->
        <TextView
            android:id="@+id/heartRateTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:layout_marginTop="20dp"/>

        <!-- PPG 실시간 차트 -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
